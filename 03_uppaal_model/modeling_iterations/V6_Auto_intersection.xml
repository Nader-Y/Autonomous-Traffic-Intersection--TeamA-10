			<source ref="id0"/>
			<target ref="id1"/>
			<label kind="guard" x="1717" y="348">queue_len &lt; MAX_WAIT</label>
			<label kind="synchronisation" x="1734" y="331">vehicle_arrive!</label>
			<label kind="assignment" x="1513" y="161">vehicleMove[generatedVehicle] = generatedMove,
vehicleActive[generatedVehicle] = true,

requestedVehicle = generatedVehicle,
requestedMove = generatedMove,

generatedVehicle = (generatedVehicle == 3 ? 0 : generatedVehicle + 1),
generatedMove = (generatedMove == 12 ? 1 : generatedMove + 1)</label>
			<nail x="1454" y="331"/>
			<nail x="2134" y="331"/>
		</transition>
